# === CONFIGURAÇÕES DO DEALERS CLUB ===
DEALERS_EMAIL=seu_email@exemplo.com
DEALERS_PASSWORD=sua_senha_aqui
DEALERS_WHITELABEL_ID=8
DEALERS_SHOP_ID=seu_shop_id
DEALERS_USER_ID=seu_user_id
DEALERS_API_URL=https://prod-backend.dealersclub.com.br/api
DEALERS_ORIGIN=https://vendadireta.dealersclub.com.br
DEALERS_AUDITORIO_ORIGIN=https://vendadireta-auditorio.dealersclub.com.br

# === CONFIGURAÇÕES DO SISTEMA ===
MARGIN_PERCENT=5
PORT=3001

# === SEGURANÇA (OBRIGATÓRIO EM PRODUÇÃO) ===
# Gere uma chave segura: openssl rand -base64 32
JWT_SECRET=GERE_UMA_CHAVE_SEGURA_AQUI

# Senha do admin (OBRIGATÓRIO)
ADMIN_USER=admin
ADMIN_PASS=DEFINA_UMA_SENHA_FORTE_AQUI

# === APIs EXTERNAS ===
FIPE_API_TOKEN=seu_token_fipe_aqui

# === NUVENDE PIX (opcional) ===
NUVENDE_CLIENT_ID=seu_client_id
NUVENDE_CLIENT_SECRET=seu_client_secret
NUVENDE_WEBHOOK_SECRET=seu_webhook_secret

# === BANCO DE DADOS ===
DATABASE_URL=postgresql://usuario:senha@localhost:5432/lanceprime
