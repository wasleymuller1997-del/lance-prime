# Chaves da conta DEMO (testnet de futuros) — crie em https://testnet.binancefuture.com
# Faça login e gere a API Key na aba "API Key" na parte de baixo da tela.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Modo de operação:
#   paper   = simulação local com preços reais (NÃO precisa de chave)
#   testnet = envia ordens reais para a conta demo (precisa das chaves acima)
BOT_MODE=paper
